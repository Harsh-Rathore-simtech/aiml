<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Do not rewrite requests for the /assets folder
    RewriteCond %{REQUEST_URI} ^/assets/ [NC]
    RewriteRule ^ - [L]

    # 2. Map the root URL (/) to /api/index.php
    RewriteRule ^$ api/index.php [L]

    # 3. Map any request ending in .php to the /api directory
    # (e.g., woodenmagic.in/about.php -> /api/about.php)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*\.php)$ api/$1 [L]

    # 4. Optional: Support extensionless URLs (e.g., woodenmagic.in/about -> /api/about.php)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/api/$1.php -f
    RewriteRule ^(.*)$ api/$1.php [L]
</IfModule>
